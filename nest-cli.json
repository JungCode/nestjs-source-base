{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "builder": {
      "type": "swc",
      "options": {
        "swcrcPath": ".swcrc.json"
      }
    },
    "deleteOutDir": true,
    "assets": [
      {
        "include": "locales/**/*.json",
        "watchAssets": true,
        "outDir": "dist"
      },
      {
        "include": "services/**/*.pug",
        "watchAssets": true,
        "outDir": "dist"
      },
      {
        "include": "db/seeder/seed-data/**/*",
        "watchAssets": true,
        "outDir": "dist"
      },
      {
        "include": "db/stored-procedures/**/*.sql",
        "watchAssets": true,
        "outDir": "dist"
      },
      {
        "include": "db/functions/*.sql",
        "watchAssets": true,
        "outDir": "dist"
      }
    ]
  }
}
